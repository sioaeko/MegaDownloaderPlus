<Window x:Class="MegaDownloaderNext.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MegaDownloaderNext.App"
        mc:Ignorable="d"
        Title="MegaDownloader+"
        Icon="Assets/AppIcon.ico"
        MinHeight="720"
        MinWidth="1180"
        Height="800"
        Width="1340"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        FontFamily="Segoe UI Variable Text, Segoe UI, Malgun Gothic"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        DragOver="MainWindow_DragOver"
        DragLeave="MainWindow_DragLeave"
        Drop="MainWindow_Drop">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48"
                      CornerRadius="12"
                      GlassFrameThickness="1"
                      NonClientFrameEdges="None"
                      ResizeBorderThickness="8" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Window.Resources>

    <Border x:Name="MainWindowBorder"
            Background="{StaticResource FillColorSecondary}"
            CornerRadius="12"
            BorderBrush="{StaticResource DividerStrokeColorDefault}"
            BorderThickness="1"
            Margin="10"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.2" ShadowDepth="0" Color="Black" />    
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Left Sidebar Navigation (Extends to Top) ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource FillColorSubtle}"
                    BorderBrush="{StaticResource DividerStrokeColorDefault}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="12,0,0,12">
            <Grid Margin="0,48,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Logo/Title -->
                <StackPanel Grid.Row="0" Margin="16,0,16,0" Orientation="Horizontal">
                    <Image Source="Assets/AppIconSidebar.png"
                           Width="44"
                           Height="44"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="False"
                           VerticalAlignment="Center" />
                    <TextBlock Text="MegaDownloader+"
                               Margin="10,0,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextFillColorPrimary}" />
                </StackPanel>

                <!-- Navigation List -->
                <ListBox x:Name="SidebarList"
                         Grid.Row="2"
                         Style="{StaticResource NavigationListBoxStyle}"
                         ItemContainerStyle="{StaticResource NavigationItemStyle}"
                         Margin="12,0"
                         SelectedIndex="0"
                         SelectionChanged="Sidebar_SelectionChanged">
                    <ListBoxItem x:Name="NavAll">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="모든 다운로드" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavDownloading">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="다운로드 중" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavCompleted">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE10B;" FontFamily="Segoe MDL2 Assets" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="완료됨" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavErrors">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="오류 발생" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <ListBox x:Name="SettingsSidebarList"
                         Grid.Row="3"
                         Style="{StaticResource NavigationListBoxStyle}"
                         ItemContainerStyle="{StaticResource NavigationItemStyle}"
                         Margin="12,0"
                         SelectionChanged="SettingsNav_SelectionChanged">
                    <ListBoxItem x:Name="NavSettings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="설정" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Border>

        <!-- ── Main Content Area (Extends to Top) ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="84" /> <!-- Unified Header & Title Bar Area -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Unified Header Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource FillColorPrimary}"
                    BorderBrush="{StaticResource DividerStrokeColorDefault}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="0,12,0,0">
                <Grid>
                    <!-- Left side: Title & Summary -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="24,0,0,16">       
                        <TextBlock x:Name="CurrentCategoryTitle"
                                   Text="모든 다운로드"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding QueueSummary}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextFillColorSecondary}" />
                    </StackPanel>

                    <!-- System Buttons (Top Right corner) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,0,2,0"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Click="MinimizeButton_Click"
                                ToolTip="최소화">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Click="MaximizeButton_Click"
                                x:Name="MaximizeButton"
                                ToolTip="최대화">
                            <TextBlock x:Name="MaximizeIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="닫기">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                    </StackPanel>

                    <!-- Action Buttons (Bottom Right, aligned with summary) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,24,12"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid Width="260"
                              Height="36"
                              Margin="0,0,12,0">
                            <TextBox x:Name="QueueSearchBox"
                                     Text="{Binding QueueSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="QueueSearch_TextChanged"
                                     Padding="36,6,34,6"
                                     ToolTip="파일명, 링크, 저장 경로 검색 (Ctrl+F)" />
                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource TextFillColorTertiary}"
                                       IsHitTestVisible="False"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                            <Button Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,4,0"
                                    Padding="0"
                                    Click="ClearQueueSearch_Click"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTip="검색 지우기">
                                <TextBlock Text="&#xE711;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <Button Click="ShowAddLinks_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="16,0"
                                Height="36"
                                Margin="0,0,12,0"
                                ToolTip="링크 추가 (Ctrl+L)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="링크 추가" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="StartButton"
                                Click="StartDownloads_Click"
                                ToolTip="시작/재개"
                                Width="40" Height="36"
                                Margin="0,0,8,0">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="StopButton"
                                ToolTip="일시 정지"
                                Click="StopDownloads_Click"
                                Width="40" Height="36"
                                Margin="0,0,8,0"
                                IsEnabled="False">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="RetryErrorsButton"
                                ToolTip="오류 재시도 (F5)"
                                Click="RetryErrors_Click"
                                Width="40" Height="36"
                                Margin="0,0,8,0">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button ToolTip="완료 정리"
                                Click="ClearCompleted_Click"
                                Width="40" Height="36"
                                Margin="0,0,8,0"
                                Style="{StaticResource SubtleButtonStyle}">
                            <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="ClearAllButton"
                                ToolTip="대기열 비우기"
                                Click="ClearAll_Click"
                                Width="40" Height="36"
                                Style="{StaticResource SubtleButtonStyle}">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Switcher -->
            <Grid Grid.Row="1">
                <!-- Queue View -->
                <Grid x:Name="QueueView">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0"
                              x:Name="DownloadGrid"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              Margin="0">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="파일 열기" Click="OpenSelectedFile_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="폴더에서 보기" Click="RevealSelectedFile_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="원본 링크 복사" Click="CopySelectedLink_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="스트리밍 재생" Click="StreamItem_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="삭제" Click="RemoveSelected_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="파일명" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                            <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource TextFillColorTertiary}"      
                                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="상태" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StateBackground}"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding StateText}"
                                                       Foreground="{Binding StateForeground}"
                                                       FontSize="11"
                                                       FontWeight="Bold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="크기" Binding="{Binding SizeText}" Width="100" />       
                            <DataGridTextColumn Header="남은 시간" Binding="{Binding EtaText}" Width="100" />

                            <DataGridTemplateColumn Header="진행률" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}" Maximum="1" Height="4" Margin="0,0,0,4" />
                                            <Grid Grid.Row="1">
                                                <TextBlock Text="{Binding ProgressText}" FontSize="10" Foreground="{StaticResource TextFillColorSecondary}" HorizontalAlignment="Left" />
                                                <TextBlock Text="{Binding SpeedText}" FontSize="10" Foreground="{StaticResource TextFillColorSecondary}" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="0"
                            x:Name="QueueEmptyPanel"
                            Panel.ZIndex="2"
                            Background="{StaticResource FillColorSecondary}"
                            Visibility="Collapsed"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Width="440"
                                    Margin="24">
                            <TextBlock Text="&#xE710;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="48"
                                       Foreground="{StaticResource AccentFillColorDefault}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16" />
                            <TextBlock x:Name="QueueEmptyTitle"
                                       Text="다운로드할 링크를 추가하세요"
                                       Style="{StaticResource TitleText}"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="QueueEmptyDescription"
                                       Text="MEGA 링크를 붙여넣거나 창 위로 끌어오면 대기열에 바로 추가됩니다."
                                       Style="{StaticResource BodySecondaryText}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,24" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Click="ShowAddLinks_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="20,0"
                                        Height="36"
                                        ToolTip="링크 추가 (Ctrl+L)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="링크 추가" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ClearEmptySearchButton"
                                        Click="ClearQueueSearch_Click"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Padding="20,0"
                                        Height="36"
                                        Margin="8,0,0,0"
                                        Visibility="Collapsed"
                                        ToolTip="검색 지우기">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="검색 지우기" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Details Pane -->
                    <Border Grid.Column="1"
                            x:Name="DetailsPane"
                            Width="360"
                            Background="{StaticResource FillColorPrimary}"
                            BorderBrush="{StaticResource DividerStrokeColorDefault}"
                            BorderThickness="1,0,0,0"
                            Visibility="{Binding SelectedItem, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                                <TextBlock Text="선택 항목 정보" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding SelectedItem.Name}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="진행 상태" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
                                    <ProgressBar Value="{Binding SelectedItem.ProgressValue, Mode=OneWay}" Maximum="1" Height="8" Margin="0,0,0,8" />

                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="현재 상태" Style="{StaticResource CaptionText}" /> 
                                            <TextBlock Text="{Binding SelectedItem.StateText}" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="다운로드 속도" Style="{StaticResource CaptionText}" />
                                            <TextBlock Text="{Binding SelectedItem.SpeedText}" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="남은 시간" Style="{StaticResource CaptionText}" />
                                    <TextBlock Text="{Binding SelectedItem.EtaText}" FontWeight="SemiBold" Margin="0,0,0,24" />

                                    <TextBlock Text="저장 경로" Style="{StaticResource LabelText}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedItem.TargetDirectory}" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="13" />

                                    <TextBlock Text="로컬 파일" Style="{StaticResource LabelText}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedItem.LocalPathText}" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="12" Foreground="{StaticResource TextFillColorSecondary}" />

                                    <TextBlock Text="원본 링크" Style="{StaticResource LabelText}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedItem.OriginalUrl}" TextWrapping="Wrap" Margin="0,0,0,24" FontSize="12" Foreground="{StaticResource TextFillColorSecondary}" />

                                    <Separator />

                                    <TextBlock Text="오류 내용" Style="{StaticResource LabelText}" Foreground="{StaticResource SystemFillColorCritical}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedItem.ErrorMessage, TargetNullValue='오류  없음'}" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="12" />
                                </StackPanel>
                            </ScrollViewer>

                            <StackPanel Grid.Row="2">
                                <Button Content="파일 열기"
                                        Click="OpenSelectedFile_Click"
                                        HorizontalAlignment="Stretch" />
                                <Button Content="폴더에서 보기"
                                        Click="RevealSelectedFile_Click"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,8,0,0" />
                                <Button x:Name="RetrySelectedButton"
                                        Content="이 항목 재시도"
                                        Click="RetrySelected_Click"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Settings View -->
                <ScrollViewer x:Name="SettingsView" Visibility="Collapsed" Padding="48">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="일반 설정" Style="{StaticResource TitleText}" Margin="0,0,0,32" />     

                        <TextBlock Text="기본 저장 위치" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding DownloadDirectory}" IsReadOnly="True" VerticalContentAlignment="Center" />
                            <Button Grid.Column="1" Content="변경..." Click="BrowseDownloadDirectory_Click" Margin="8,0,0,0" />
                        </Grid>

                        <TextBlock Text="동시 다운로드 제한" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                        <ComboBox ItemsSource="{Binding ConcurrentDownloadChoices}"
                                  SelectedItem="{Binding ConcurrentDownloads}"
                                  Width="120" HorizontalAlignment="Left" Margin="0,0,0,32" />

                        <TextBlock Text="추가 옵션" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />  
                        <CheckBox Content="클립보드 MEGA 링크 자동 감지" IsChecked="{Binding AutoDetectClipboardLinks}" Margin="0,0,0,12" />
                        <CheckBox Content="링크 추가 시 자동으로 다운로드 시작" IsChecked="{Binding AutoStartAfterAdd}" Margin="0,0,0,12" />
                        <CheckBox Content="MEGA 대역폭 제한 시 자동으로 일시 정지" IsChecked="{Binding StopOnBandwidthLimit}" Margin="0,0,0,12" />
                        <CheckBox Content="다운로드 완료 후 자동으로 압축 해제" IsChecked="{Binding AutoExtract}" Margin="0,0,0,32" />

                        <TextBlock Text="MEGA 계정" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="이메일" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,12,10" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding MegaEmail, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="MegaAccountInput_KeyDown"
                                     Height="34"
                                     HorizontalContentAlignment="Left"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="비밀번호" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,12,10" />
                            <PasswordBox Grid.Row="1" Grid.Column="1"
                                         x:Name="MegaPasswordInput"
                                         KeyDown="MegaAccountInput_KeyDown"
                                         Height="34"
                                         HorizontalContentAlignment="Left"
                                         VerticalContentAlignment="Center"
                                         PasswordChar="&#x2022;"
                                         Margin="0,0,0,10" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="2FA 코드" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     x:Name="MegaMfaInput"
                                     MaxLength="16"
                                     Height="34"
                                     HorizontalContentAlignment="Left"
                                     KeyDown="MegaAccountInput_KeyDown"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                        <CheckBox Content="로그인 유지"
                                  IsChecked="{Binding RememberMegaLogin}"
                                  Checked="MegaSettingsChanged"
                                  Unchecked="MegaSettingsChanged"
                                  Margin="0,0,0,12" />
                        <TextBlock Text="{Binding MegaAccountStatusText}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                            <Button x:Name="MegaLoginButton"
                                    Content="로그인"
                                    Click="MegaLogin_Click"
                                    Padding="20,8"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="MegaLogoutButton"
                                    Content="로그아웃"
                                    Click="MegaLogout_Click"
                                    Padding="20,8"
                                    Margin="8,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="미디어 플레이어 설정 (스트리밍용)" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding MediaPlayerPath}" VerticalContentAlignment="Center" />                            <Button Grid.Column="1" Content="찾아보기..." Click="BrowseMediaPlayer_Click" Margin="8,0,0,0" />
                        </Grid>

                        <Button Content="다운로드 폴더 열기" Click="OpenDownloadDirectory_Click" Padding="24,8" />                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ── Drop Hint Overlay ── -->
        <Border x:Name="DropHintOverlay"
                Grid.ColumnSpan="2"
                Panel.ZIndex="10"
                Background="#B8FFFFFF"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Border Background="{StaticResource FillColorPrimary}"
                    BorderBrush="{StaticResource AccentFillColorDefault}"
                    BorderThickness="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="520"
                    CornerRadius="12"
                    Padding="32"
                    Effect="{StaticResource CardShadowHover}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8E5;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="42"
                               Foreground="{StaticResource AccentFillColorDefault}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                    <TextBlock Text="MEGA 링크 드롭"
                               Style="{StaticResource TitleText}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="링크 텍스트 또는 .txt/.url 파일을 놓으면 대기열에 추가됩니다."
                               Style="{StaticResource BodySecondaryText}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="420" />
                </StackPanel>
            </Border>
        </Border>

        <!-- ── Add Links Overlay ── -->
        <Border x:Name="AddLinksOverlay"
                Grid.ColumnSpan="2"
                Panel.ZIndex="20"
                Background="#80000000"
                Visibility="Collapsed"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Border Background="{StaticResource FillColorPrimary}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="640"
                    CornerRadius="12"
                    Padding="32"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="MEGA 링크 추가" Style="{StaticResource TitleText}" Margin="0,0,0,8" />     
                    <TextBlock Text="여러 개의 링크를 줄바꿈으로 구분하여 입력할 수 있습니다."
                               Style="{StaticResource CaptionText}" Margin="0,0,0,24" />

                    <TextBox x:Name="LinkInput"
                             Height="240"
                             AcceptsReturn="True"
                             KeyDown="LinkInput_KeyDown"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,32" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Content="취소" Click="HideAddLinks_Click" Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Left" Width="100" />

                        <Button Grid.Column="2"
                                Content="큐에 추가하기"
                                Click="AddLinks_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                Width="160" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Status Message -->
        <Border Grid.Column="1"
                Panel.ZIndex="30"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,32"
                Background="{StaticResource ShellFillColor}" CornerRadius="20" Padding="20,10"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                x:Name="StatusToast">
            <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="13" />
        </Border>
    </Grid>
    </Border>
</Window>
